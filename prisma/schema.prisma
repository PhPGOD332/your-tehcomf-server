generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  USER
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  refreshTokenHash      String?   @map("refresh_token_hash")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  role                  Role      @default(USER)
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Image {
  id       Int                   @id(map: "images_pk") @default(autoincrement())
  imageAlt String                @map("image_alt")
  width    Int?
  height   Int?
  order    Int?                  @map("order")
  s3Key    String?               @map("s3_key")
  src      String
  images   PortfolioImagesList[]

  @@map("nsi_images")
}

model Color {
  id            Int                   @id(map: "nsi_colors_pk") @default(autoincrement())
  name          String
  caption       String
  hexCode       String                @map("hex_code")
  captionCode   String?               @map("caption_code")
  bodyWorks     Portfolio[]           @relation("BodyColor")
  tableTopWorks Portfolio[]           @relation("TableTopColor")
  palette       PortfolioColorsList[]

  @@map("nsi_colors")
}

model FilterColor {
  id         Int         @id(map: "nsi_filter_colors_pk") @default(autoincrement())
  name       String
  caption    String
  type       String
  order      Int
  portfolios Portfolio[]

  @@map("nsi_filter_colors")
}

model FilterLayout {
  id      Int         @id(map: "nsi_filter_styles_pk") @default(autoincrement())
  name    String
  caption String
  type    String
  order   Int
  works   Portfolio[]

  @@map("nsi_filter_layouts")
}

model FilterStyle {
  id      Int         @id @default(autoincrement())
  name    String
  caption String
  type    String
  order   Int
  works   Portfolio[]

  @@map("nsi_filter_styles")
}

model FilterBudget {
  id       Int    @id(map: "nsi_filter_budget_pk") @default(autoincrement())
  minValue Int?   @map("min_value")
  maxValue Int?   @map("max_value")
  caption  String
  name     String
  type     String
  order    Int

  @@map("nsi_filter_budgets")
}

model FilterType {
  id          Int         @id(map: "nsi_filter_types_pk") @default(autoincrement())
  name        String
  caption     String
  type        String
  cardCaption String?     @map("card_caption")
  works       Portfolio[]

  @@map("nsi_filter_types")
}

model Portfolio {
  id                   Int                   @id(map: "portfolio_pk") @default(autoincrement())
  typeId               Int?                  @map("type")
  sizesRoom            String?               @map("sizes_room")
  sizesFurniture       String?               @map("sizes_furniture")
  housingMaterial      String?               @map("housing_material")
  facadeMaterial       String?               @map("facade_material")
  tableTopMaterial     String?               @map("table_top_material")
  bodyColorId          Int?                  @map("body_color")
  tableTopColorId      Int?                  @map("table_top_color")
  furnitureAccessories String?               @map("furniture_accessories")
  name                 String
  title                String
  layoutId             Int?                  @map("layout")
  price                Int
  description          String?
  styleId              Int?                  @map("style")
  colorId              Int?                  @map("color")
  subtitle             String?
  bodyColor            Color?                @relation("BodyColor", fields: [bodyColorId], references: [id])
  color                FilterColor?          @relation(fields: [colorId], references: [id])
  layout               FilterLayout?         @relation(fields: [layoutId], references: [id])
  style                FilterStyle?          @relation(fields: [styleId], references: [id])
  tableTopColor        Color?                @relation("TableTopColor", fields: [tableTopColorId], references: [id])
  type                 FilterType?           @relation(fields: [typeId], references: [id])
  colorsList           PortfolioColorsList[]
  imagesList           PortfolioImagesList[]

  @@map("portfolio")
}

model PortfolioColorsList {
  id      Int        @id(map: "portfolio_colors_list_pk") @default(autoincrement())
  workId  Int?       @map("work")
  colorId Int?       @map("color")
  color   Color?     @relation(fields: [colorId], references: [id])
  work    Portfolio? @relation(fields: [workId], references: [id])

  @@map("portfolio_colors_list")
}

model PortfolioImagesList {
  id      Int        @id(map: "portfolio_images_list_pk") @default(autoincrement())
  workId  Int?       @map("work")
  imageId Int?       @map("image")
  image   Image?     @relation(fields: [imageId], references: [id])
  work    Portfolio? @relation(fields: [workId], references: [id])

  @@map("portfolio_images_list")
}

model Category {
  id        Int        @id(map: "categories_pk") @default(autoincrement())
  category  String
  questions Question[]

  @@map("nsi_questions_categories")
}

model Question {
  id                  Int       @id(map: "questions_pk") @default(autoincrement())
  question            String
  categoryId          Int?      @map("categoryId")
  questionDescription String    @map("question_description")
  category            Category? @relation(fields: [categoryId], references: [id])

  @@map("questions")
}
